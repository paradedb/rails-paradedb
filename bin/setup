#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

echo "==> Installing dependencies"

bundle install

echo ""
echo "==> Done"
echo "Run unit tests: scripts/run_unit_tests.sh"
echo "Run integration tests (requires ParadeDB): scripts/run_integration_tests.sh"
