#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../scripts" && pwd)"

"${SCRIPT_DIR}/rbenv_bootstrap.sh"

ruby_runner=()
if ! ruby --version | grep -qE "ruby 4\.(0|1)"; then
  if command -v rbenv >/dev/null 2>&1; then
    ruby_runner=(rbenv exec)
  fi
fi

if ! "${ruby_runner[@]}" gem list -i rubocop >/dev/null 2>&1; then
  "${ruby_runner[@]}" gem install rubocop --no-document
fi

"${ruby_runner[@]}" rubocop --lint lib spec rails-paradedb.gemspec Rakefile "$@"
